<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX v5 authoring for the Catala Windows MSI.

  Build (on a Windows machine with the WiX dotnet tool installed):

    wix build wix\Catala.wxs `
      -ext WixToolset.Util.wixext `
      -ext WixToolset.UI.wixext `
      -d Version=0.11.0 `
      -d StageDir=_bundle\stage\catala-0.11.0-windows-x86_64 `
      -arch x64 `
      -o _bundle\catala-0.11.0-windows-x86_64.msi

  Two preprocessor variables are required:
    Version   - 3- or 4-part numeric MSI ProductVersion (e.g. 0.11.0)
    StageDir  - the staging tree assembled by build-bundle.ps1; its contents
                (bin\ and toolchain\) are harvested into the install folder.

  Design choices (see DESIGN.md):
    - perUser scope: installs to %LOCALAPPDATA%\Programs\Catala with NO admin /
      no UAC. IT can push per-machine by building with -d Scope=perMachine and
      running elevated (msiexec ALLUSERS=1 /qn); a follow-up variant.
    - PATH: the install's bin\ is added to the *user* PATH (HKCU).
    - Defender exclusions are an opt-in, self-elevating extra (TUNE_DEFENDER=1),
      never required for install to succeed. See defender.ps1.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!-- The opt-in Defender custom action can be compiled out (-d Defender=0) to
       validate the core MSI independently of the Util extension CA binary. -->
  <?ifndef Defender ?>
  <?define Defender = "1" ?>
  <?endif?>

  <!-- Install scope. Default perMachine (C:\ProgramData\Catala, elevated, system
       PATH/HKLM) — the shipped variant. Build with -d Scope=perUser for a no-admin
       per-user install (%LOCALAPPDATA%, user PATH/HKCU). ProgramData (not Program
       Files) keeps the path space-free for clerk's not-yet-space-hardened rules. -->
  <?ifndef Scope ?>
  <?define Scope = "perMachine" ?>
  <?endif?>
  <?if $(var.Scope) = "perMachine" ?>
  <?define RegRoot = "HKLM" ?>
  <?define EnvSystem = "yes" ?>
  <!-- Deferred CAs run in the system (elevated) context to write under ProgramData. -->
  <?define DeferredImpersonate = "no" ?>
  <?else?>
  <?define RegRoot = "HKCU" ?>
  <?define EnvSystem = "no" ?>
  <!-- Per-user install isn't elevated; deferred CAs run as the user (writes LOCALAPPDATA). -->
  <?define DeferredImpersonate = "yes" ?>
  <?endif?>

  <Package
      Name="Catala"
      Manufacturer="Inria"
      Version="$(var.Version)"
      Scope="$(var.Scope)"
      UpgradeCode="6f2a1c5e-3d4b-4a7e-9b1f-2c8d5e6a7b90"
      Compressed="yes"
      InstallerVersion="500">

    <!-- Block downgrades; allow same-version repair and newer-version upgrade. -->
    <MajorUpgrade
        AllowSameVersionUpgrades="yes"
        DowngradeErrorMessage="A newer version of Catala is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Property Id="ARPURLINFOABOUT" Value="https://catala-lang.org" />

    <!-- VS Code extension is offered as an optional, default-on FEATURE (the
         "VSCodeExt" feature below) so WixUI_FeatureTree renders it as a native
         check box — no fragile custom-dialog authoring. Ticking it installs a
         Start-Menu shortcut to install-vscode-extension.cmd, which the user runs
         in their own shell (a per-machine MSI runs as SYSTEM, but VS Code
         extensions install per-user). Graceful degradation lives in the .cmd: it
         does `where code` and prints "install VS Code first" rather than failing
         when VS Code is absent, so leaving it ticked is harmless either way. -->


    <?if $(var.Scope) = "perMachine" ?>
    <!-- C:\ProgramData\Catala (per-machine, elevated). CommonAppDataFolder is
         the machine-wide standard location WiX can auto-GUID. It is also
         space-free: clerk now quotes exe paths in its ninja commands (catala
         dbdfcb442, validated on a "C:\sp ace" install), but a few include-dir
         paths may still be unquoted, so a space-free root remains the safe
         default until that hardening lands. -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="Catala" />
    </StandardDirectory>
    <?else?>
    <!-- %LOCALAPPDATA%\Programs\Catala (per-user, no admin). -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="Catala" />
      </Directory>
    </StandardDirectory>
    <?endif?>

    <!-- Start-Menu folder for the (optional) VS Code extension installer shortcut. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="CatalaMenuFolder" Name="Catala" />
    </StandardDirectory>

    <Feature Id="Main" Title="Catala toolchain" Level="1"
             Description="The Catala compiler, clerk, the language server and formatter."
             AllowAbsent="no" AllowAdvertise="no">
      <ComponentGroupRef Id="ToolchainFiles" />
      <ComponentRef Id="EnvPath" />
      <?if $(var.Defender) = "1" ?>
      <ComponentRef Id="DefenderMarker" />
      <?endif?>
    </Feature>

    <!-- Optional, default-on. WixUI_FeatureTree shows this as a check box the
         user can untick. Ticked: install the extension into VS Code now AND drop
         a Start-Menu shortcut to reinstall it later. Unticked: neither. -->
    <Feature Id="VSCodeExt" Level="1" Title="VS Code extension"
             Description="Installs the Catala extension into VS Code now (and adds a Start-Menu shortcut to reinstall it later). Requires VS Code; skipped harmlessly if VS Code is not installed."
             AllowAdvertise="no">
      <ComponentRef Id="VSCodeExtShortcut" />
    </Feature>

    <!--
      Harvest the whole staging tree. The WiX v4/v5 <Files> element globs the
      directory and auto-generates one component per file, mirroring the
      subdirectory structure (bin\, toolchain\...) under INSTALLFOLDER.
    -->
    <ComponentGroup Id="ToolchainFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.StageDir)\**" />
    </ComponentGroup>

    <!-- Add bin\ to PATH (user/HKCU for perUser, system/HKLM for perMachine).
         The registry value is the component keypath. -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="EnvPath" Guid="b3d9a2f1-7c44-4e2a-8f6b-1d0c3e5a4b21">
        <RegistryValue Root="$(var.RegRoot)" Key="Software\Catala"
                       Name="InstallDir" Type="string" Value="[INSTALLFOLDER]"
                       KeyPath="yes" />
        <Environment Id="PATH" Name="PATH" Value="[INSTALLFOLDER]bin"
                     Part="last" Action="set" Permanent="no" System="$(var.EnvSystem)" />
      </Component>

      <?if $(var.Defender) = "1" ?>
      <!--
        Marker written only when the user opted into Defender exclusions.
        Its presence drives the uninstall-time removal (so we don't pop a UAC
        prompt on uninstall for users who never added exclusions).
      -->
      <Component Id="DefenderMarker" Guid="c4e0b3a2-8d55-4f3b-9a7c-2e1d4f6b5c32"
                 Condition="TUNE_DEFENDER=&quot;1&quot;">
        <RegistryValue Root="$(var.RegRoot)" Key="Software\Catala"
                       Name="DefenderExclusions" Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
      <?endif?>
    </DirectoryRef>

    <!-- Optional Start-Menu shortcut to the VS Code extension installer. Only
         installed when the UI checkbox (INSTALLVSCODEEXT) is on. The shortcut
         just runs install-vscode-extension.cmd, which degrades gracefully when
         VS Code is absent, so shipping it is harmless either way. -->
    <DirectoryRef Id="CatalaMenuFolder">
      <Component Id="VSCodeExtShortcut" Guid="d5f1c4b3-9e66-4a5c-8b2d-3f0e1a2b4c56">
        <Shortcut Id="InstallVSCodeExt"
                  Name="Install Catala VS Code extension"
                  Description="Installs the bundled Catala extension into VS Code (requires VS Code)."
                  Target="[INSTALLFOLDER]install-vscode-extension.cmd"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveCatalaMenuFolder" On="uninstall" />
        <RegistryValue Root="$(var.RegRoot)" Key="Software\Catala"
                       Name="VSCodeShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- =====================================================================
         Grammar config (always): point catala.ncl at the bundled prebuilt
         grammar .dlls via topiary's grammar.source.path (>= 0.6, PR #747). The
         absolute path is only known now and differs per scope, so we resolve it
         at install rather than baking it at build time. Deferred CA runs after
         the files are on disk; immediate type-51 marshals [INSTALLFOLDER] into
         its CustomActionData. Return=check -> formatting must be wired correctly.
         ===================================================================== -->
    <CustomAction Id="ConfigureGrammar" BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" Execute="deferred"
                  Impersonate="$(var.DeferredImpersonate)" Return="check" />
    <CustomAction Id="SetConfigureGrammar" Property="ConfigureGrammar"
                  Execute="immediate"
                  Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]toolchain\libexec\grammar-config.ps1&quot; -InstallDir &quot;[INSTALLFOLDER]&quot;" />

    <!-- =====================================================================
         Direct VS Code extension install (only when the VSCodeExt feature is
         selected). Impersonate=yes -> runs as the invoking user even for a
         perMachine (SYSTEM) install, because extensions are per-user. The
         script exits 0 when VS Code is absent and Return=ignore makes the CA
         non-fatal, so it never blocks the install. The Start-Menu shortcut
         stays as a fallback (silent/SYSTEM installs, or admin != end user).
         ===================================================================== -->
    <CustomAction Id="InstallVSCodeExt" BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" Execute="deferred"
                  Impersonate="yes" Return="ignore" />
    <!-- NOTE: no -InstallDir argument. [INSTALLFOLDER] ends in a backslash, so
         "[INSTALLFOLDER]" would become ...Catala\" and the \" escapes the closing
         quote (the arg gets mangled -> the script can't find the .vsix). The
         script derives its install dir from $PSScriptRoot instead. -->
    <CustomAction Id="SetInstallVSCodeExt" Property="InstallVSCodeExt"
                  Execute="immediate"
                  Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]toolchain\libexec\install-vscode-ext.ps1&quot;" />

    <?if $(var.Defender) = "1" ?>
    <!-- =====================================================================
         Defender exclusions (opt-in, self-elevating, non-fatal)
         ===================================================================== -->

    <!-- Opt in with TUNE_DEFENDER=1 on the command line (or a UI checkbox,
         TODO). Public property so it survives the deferred sequence. -->
    <Property Id="TUNE_DEFENDER" Value="0" Secure="yes" />

    <!-- On uninstall, only remove exclusions if the marker was set at install. -->
    <Property Id="DEFENDER_WAS_TUNED">
      <RegistrySearch Id="DefenderMarkerSearch" Root="$(var.RegRoot)"
                      Key="Software\Catala" Name="DefenderExclusions"
                      Type="raw" />
    </Property>

    <!-- Deferred CAs that run the script; they read their command line from the
         CustomActionData, i.e. the property whose name equals the CA id.
         Impersonate=yes -> runs as the (possibly non-elevated) user, and
         defender.ps1 self-elevates via UAC. Return=ignore -> non-fatal.
         NOTE: confirm the Util CA BinaryRef id matches the installed extension
         (e.g. Wix4UtilCA_X64) on first build. -->
    <CustomAction Id="TuneDefenderAdd" BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" Execute="deferred"
                  Impersonate="yes" Return="ignore" />
    <CustomAction Id="TuneDefenderRemove" BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64" Execute="deferred"
                  Impersonate="yes" Return="ignore" />

    <!-- Immediate type-51 actions that marshal each command line into the
         matching deferred CA's CustomActionData. Distinct ids from the deferred
         CAs; Property= names the deferred CA. [INSTALLFOLDER]/[System64Folder]
         are resolved by the time these run (after CostFinalize). -->
    <CustomAction Id="SetTuneDefenderAdd" Property="TuneDefenderAdd"
                  Execute="immediate"
                  Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]toolchain\libexec\defender.ps1&quot; -Add -SelfElevate -InstallDir &quot;[INSTALLFOLDER]&quot;" />
    <CustomAction Id="SetTuneDefenderRemove" Property="TuneDefenderRemove"
                  Execute="immediate"
                  Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]toolchain\libexec\defender.ps1&quot; -Remove -SelfElevate -Quiet -InstallDir &quot;[INSTALLFOLDER]&quot;" />

    <?endif?>

    <InstallExecuteSequence>
      <!-- Grammar config: after files are on disk, on fresh install / repair /
           upgrade (NOT on uninstall, where the file is removed with its component). -->
      <Custom Action="SetConfigureGrammar" After="InstallFiles"
              Condition="NOT Installed OR REINSTALL" />
      <Custom Action="ConfigureGrammar" After="SetConfigureGrammar"
              Condition="NOT Installed OR REINSTALL" />

      <!-- Direct extension install when the VS Code feature is selected for
           local install (&VSCodeExt=3), on fresh install / repair / upgrade. -->
      <Custom Action="SetInstallVSCodeExt" After="ConfigureGrammar"
              Condition="&amp;VSCodeExt=3 AND (NOT Installed OR REINSTALL)" />
      <Custom Action="InstallVSCodeExt" After="SetInstallVSCodeExt"
              Condition="&amp;VSCodeExt=3 AND (NOT Installed OR REINSTALL)" />

      <?if $(var.Defender) = "1" ?>
      <!-- Add after files are on disk (defender.ps1 must exist), on fresh
           install / change when opted in. -->
      <Custom Action="SetTuneDefenderAdd" After="ConfigureGrammar"
              Condition="TUNE_DEFENDER=&quot;1&quot; AND NOT Installed" />
      <Custom Action="TuneDefenderAdd" After="SetTuneDefenderAdd"
              Condition="TUNE_DEFENDER=&quot;1&quot; AND NOT Installed" />
      <!-- Remove on uninstall, only if exclusions were previously added.
           Runs before files are gone so defender.ps1 still exists. -->
      <Custom Action="SetTuneDefenderRemove" Before="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot; AND DEFENDER_WAS_TUNED" />
      <Custom Action="TuneDefenderRemove" After="SetTuneDefenderRemove"
              Condition="REMOVE=&quot;ALL&quot; AND DEFENDER_WAS_TUNED" />
      <?endif?>
    </InstallExecuteSequence>

    <!-- FeatureTree UI: welcome -> license -> feature checkboxes -> confirm.
         The feature tree gives a native check box for the optional VS Code
         extension shortcut (see the VSCodeExt feature). The Defender option
         stays command-line driven (TUNE_DEFENDER=1) for now. -->
    <ui:WixUI Id="WixUI_FeatureTree" />
    <WixVariable Id="WixUILicenseRtf" Value="$(sys.SOURCEFILEDIR)license.rtf" />

  </Package>
</Wix>
